# Sanity
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Never expose this in the browser bundle
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Snippe Payment Gateway (server-side only)
SNIPPE_API_KEY=snp_your_key_here
SNIPPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Override base URL for webhooks/redirects (e.g. ngrok for local dev, omit in production)
APP_URL=https://your-subdomain.ngrok-free.app
